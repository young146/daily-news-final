// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NewsItem {
  id          String   @id @default(uuid())
  title       String
  summary     String?
  content     String?  // HTML or Markdown
  originalUrl String?
  imageUrl    String?
  category    String   // Society, Economy, Culture, Politics, International, Korea-Vietnam, Community
  source      String?  // VnExpress, Yonhap, etc.
  viewCount   Int?     // 조회수 또는 메인 페이지 순서 (낮을수록 높은 우선순위)
  
  // Translation Fields
  translatedTitle   String?
  translatedSummary String?
  translatedContent String?
  translationStatus String   @default("PENDING") // PENDING, DRAFT, COMPLETED

  // Publishing Status
  isSelected        Boolean  @default(false) // For "Top News" list
  isTopNews         Boolean  @default(false) // The ONE top news
  isPublishedMain   Boolean  @default(false) // chaovietnam.co.kr
  isPublishedDaily  Boolean  @default(false) // daily.chaovietnam.co.kr
  isCardNews        Boolean  @default(false) // Selected for Card News (Top 1 + 4 others)
  isSentSNS         Boolean  @default(false) // Facebook, Kakao
  wordpressUrl      String?  // URL of the published post on WordPress
  wordpressImageUrl String?  // URL of uploaded image in WordPress media library
  wordpressMediaId  Int?     // Media ID of uploaded image for featured_media
  localImagePath    String?  // Local file path in public/images/news/ folder
  
  htmlContent       String?  // Generated HTML for email
  publishedAt       DateTime?
  status            String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CrawlerLog {
  id           Int      @id @default(autoincrement())
  runAt        DateTime @default(now())
  status       String   // SUCCESS, PARTIAL, FAILED
  itemsFound   Int      @default(0)
  message      String?
  errorDetails String?  // JSON string with detailed error info per source
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?  // Hashed
  role      String   @default("USER") // ADMIN, USER
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  company   String?
  name      String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PromoCard {
  id          Int      @id @default(autoincrement())
  title       String                    // 카드 제목
  description String?  @db.Text         // 홍보 문구/설명
  imageUrl    String?                   // Firebase Storage 이미지 URL
  videoUrl    String?                   // YouTube 등 동영상 URL (선택)
  linkUrl     String                    // 클릭 시 이동 링크
  isActive    Boolean  @default(true)   // ON/OFF
  sortOrder   Int      @default(0)      // 정렬 순서 (낮을수록 먼저)
  // 분류 — "ad" = 광고주 카드 (수익원) / "self" = 자체 홍보 라이브러리 (앱 설치 등)
  kind        String   @default("ad")
  // 자체 홍보 카드의 용도 — "app" | "magazine" | "event" | "other"
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind, isActive, sortOrder])
}

model TestEmail {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?                      // 이름 (선택)
  createdAt DateTime @default(now())
}

model EmailSendLog {
  id         Int               @id @default(autoincrement())
  sentAt     DateTime          @default(now())   // 발송 일시
  subject    String                              // 이메일 제목
  method     String                              // 'resend' | 'smtp'
  total      Int                                 // 총 발송 시도
  succeeded  Int               @default(0)       // 성공
  failed     Int               @default(0)       // 실패
  batches    Int               @default(0)       // 배치 수
  note       String?                             // 비고 (오류 메시지 등)
  details    EmailSendDetail[]                   // 개별 발송 결과
}

model EmailSendDetail {
  id        Int          @id @default(autoincrement())
  logId     Int                                  // FK → EmailSendLog
  log       EmailSendLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  email     String                               // 수신자 이메일
  status    String                               // 'success' | 'failed'
  errorMsg  String?                              // 실패 시 오류 메시지
  sentAt    DateTime     @default(now())

  @@index([logId])
  @@index([status])
  @@index([email])
}

model ClickLog {
  id        Int      @id @default(autoincrement())
  url       String   // The destination URL that was clicked
  type      String   // Category of the link: 'NEWS', 'PROMO', 'TERMINAL'
  userIp    String?  // Optional IP address for analytics
  userAgent String?  // Optional device/browser info
  clickedAt DateTime @default(now())

  @@index([url])
  @@index([type])
  @@index([clickedAt])
}
