# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite database (each environment has its own)
prisma/dev.db
prisma/dev.db-journal
*.db.backup
.env*.local

# SendGrid suppression/bounce export files (개인정보 포함)
suppression_bounces*.csv
bounced-list.txt

# 로그/디버그 출력 파일
bounce-logs.txt
