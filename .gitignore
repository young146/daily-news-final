# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite database (each environment has its own)
prisma/dev.db
prisma/dev.db-journal
*.db.backup
.env*.local

# SendGrid suppression/bounce export files (개인정보 포함)
suppression_bounces*.csv
bounced-list.txt

# 로그/디버그 출력 파일
bounce-logs.txt
bounce_debug_output.txt

# KOTRA/진출업체 디렉토리 작업 — 데이터·산출물만 제외, *코드(.py, .md)는 git 에 올림*
# 원본 데이터 (큰 xlsx, OneDrive 등 별도 보관)
*.xlsx
# 스크래퍼 산출물 (kocham_*.csv/log/html/json) — 스크래퍼 재실행으로 재생성 가능
kocham_*.csv
kocham_*.log
kocham_*.html
kocham_*.json
# 디렉토리 미리보기 (자동 생성)
company_directory_preview.html
company_directory_preview_data.json
# subscriber/CRM export 결과 (재실행으로 재생성)
subscribers_export.csv
wp_companies_import.csv
# 파이썬 바이트코드 캐시
__pycache__/

# Claude 스케줄러 락파일 (로컬 전용)
.claude/scheduled_tasks.lock

